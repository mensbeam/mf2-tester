#!/usr/bin/env bash

if [ "$1" = "test" ]; then
    HOME=`pwd` carton exec `pwd`/test-one.pl "$2"
elif [ "$1" = "version" ]; then
    HOME=`pwd` carton show 'Web::Microformats2' | cut -d '-' -f 3
elif [ "$1" = "compile" ]; then
    true
elif [ "$1" = "setup" ]; then
    HOME=`pwd` carton install >/dev/null
elif [ "$1" = "update" ]; then
    HOME=`pwd` carton update >/dev/null
fi